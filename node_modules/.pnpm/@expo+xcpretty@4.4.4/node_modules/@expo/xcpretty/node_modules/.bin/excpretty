#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/kali/emprendedorismo/MecanicosYa/node_modules/.pnpm/@expo+xcpretty@4.4.4/node_modules/@expo/xcpretty/node_modules:/home/kali/emprendedorismo/MecanicosYa/node_modules/.pnpm/@expo+xcpretty@4.4.4/node_modules:/home/kali/emprendedorismo/MecanicosYa/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/kali/emprendedorismo/MecanicosYa/node_modules/.pnpm/@expo+xcpretty@4.4.4/node_modules/@expo/xcpretty/node_modules:/home/kali/emprendedorismo/MecanicosYa/node_modules/.pnpm/@expo+xcpretty@4.4.4/node_modules:/home/kali/emprendedorismo/MecanicosYa/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../build/cli.js" "$@"
else
  exec node  "$basedir/../../build/cli.js" "$@"
fi
